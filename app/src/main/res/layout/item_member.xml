<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_member_row"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <TextView
        android:id="@+id/textMemberIndex"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/bg_member_inner"
        android:gravity="center"
        android:text="1"
        android:textColor="@color/mp_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textMemberName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/mp_text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textMemberAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/mp_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
